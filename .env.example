# ============================================
# Sovereign Watch - Environment Configuration
# ============================================
# Copy this file to .env and customize values

# --- Location Center (All Services Use This) ---
# These coordinates define the monitoring region center
# Used by: adsb-poller, ais-poller, frontend map
CENTER_LAT=45.5152
CENTER_LON=-122.6784
COVERAGE_RADIUS_NM=150

# --- Tactical & System ---
# Interval for evicting stale aircraft arbitration entries (seconds)
ARBITRATION_CLEANUP_INTERVAL=30

# --- JS8Call Radio Terminal ---
# KiwiSDR source for headless JS8Call audio ingestion
KIWI_HOST=kiwisdr.example.com
KIWI_PORT=8073
KIWI_FREQ=14074
KIWI_MODE=usb
# Operator's Maidenhead locator (for distance/bearing)
MY_GRID=CN85

# --- Authentication ---
# Set to false to disable authentication entirely (local development only — NEVER in production)
AUTH_ENABLED=true
# Secret key for signing JWT tokens — REQUIRED. Generate with: openssl rand -hex 32
# The stack will refuse to start if this is missing or empty.
JWT_SECRET_KEY=
# Cryptographic algorithm for JWT (default: HS256)
JWT_ALGORITHM=HS256
# JWT access token lifetime in minutes (default: 480 = 8 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
# First-run admin setup is handled via the web UI (or manage.py for headless deployments).
# See: docker exec sovereign-backend python manage.py create-admin

# --- Database ---
# Required — no default. Use a strong random value: openssl rand -hex 32
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sovereign_watch

# --- Backend Configuration ---
TRACK_HISTORY_MAX_LIMIT=1000
TRACK_HISTORY_MAX_HOURS=168
TRACK_REPLAY_MAX_LIMIT=10000
TRACK_REPLAY_MAX_HOURS=168
TRACK_SEARCH_MAX_LIMIT=100

# Comma-separated list of RSS feed URLs. 
# Leave commented out to use the default feeds (BBC World, Reddit News, Al Jazeera).
# NEWS_RSS_URLS=https://feeds.bbci.co.uk/news/world/rss.xml,https://www.reddit.com/r/news/top/.rss,https://www.aljazeera.com/xml/rss/all.xml

# --- AIS Poller---
AISSTREAM_API_KEY=your_key_here

# --- Space Pulse ---
# UTC hour (0-23) at which Celestrak TLE refreshes are allowed to run.
# Set to -1 to disable hour gating and fetch immediately when interval elapses.
SPACE_TLE_FETCH_HOUR=2
SATNOGS_DB_INTERVAL_H=24
SATNOGS_NETWORK_INTERVAL_H=1
AURORA_INTERVAL_S=300
KP_INTERVAL_S=900
SCALES_INTERVAL_S=900

# --- Infrastructure ---
# UTC hour (0-23) at which the weekly FCC tower sync is allowed to run.
# Set to -1 to trigger immediately regardless of hour.
POLL_FCC_START_HOUR=3
# NDBC latest observations polling interval in minutes.
POLL_INTERVAL_NDBC_MINUTES=15
POLL_INTERVAL_PEERINGDB_HOURS=24
POLL_INTERVAL_ISS_SECONDS=5
POLL_INTERVAL_NWS_MINUTES=10

# --- OpenSky Network (optional supplemental ADS-B source) ---
# Anonymous access works without credentials but is limited to ~1 req/5 min.
# Authenticated access (OAuth2 client credentials) raises the limit to ~1 req/22 s.
# Both modes share the daily budget: 400 req/day (anon) or 8,000 req/day (auth).
# Create credentials at: https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_ENABLED=false
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret
# Optional: override the polling interval in seconds (0 = use safe default)
OPENSKY_RATE_LIMIT_PERIOD=0
# Optional: separate rate limit for watchlist queries (for slower testing pacing).
# Useful during development to test with e.g., 60-120s between watchlist requests
# while keeping bbox queries faster. Defaults to OPENSKY_RATE_LIMIT_PERIOD if not set.
OPENSKY_WATCHLIST_RATE_LIMIT_PERIOD=0
# OpenSky Global Watchlist — track specific aircraft anywhere in the world
OPENSKY_WATCHLIST_ENABLED=false
# Auto-seed: when an aircraft of a matching affiliation type is spotted in
# the primary AOR, its ICAO24 is added to the watchlist automatically so
# tracking continues after it leaves local coverage.
OPENSKY_WATCHLIST_AUTO_SEED=true
# Affiliation types to auto-seed (comma-separated, from classify_aircraft output)
OPENSKY_WATCHLIST_SEED_TYPES=military,government,drone
# TTL for auto-seeded entries in days (0 = permanent, never expires)
OPENSKY_WATCHLIST_TTL_DAYS=7
# Max ICAO24 addresses per OpenSky API request (URL length limit ~100)
OPENSKY_WATCHLIST_BATCH_SIZE=100

# --- Aviation Ingestion (Holding Pattern Detection) ---
# Degrees of total turn required within the observation window to flag a holding pattern.
HOLDING_PATTERN_THRESHOLD=360
# Rolling observation window in seconds (default 300s = 5 min).
HOLDING_WINDOW_S=300
# Minimum heading change in degrees to process (noise filter).
HEADING_CHANGE_THRESHOLD=2
# Minimum duration in seconds an aircraft must be circling to be flagged.
MIN_CIRCLE_DURATION=90
# Dominant turn-direction ratio required (1.0 = fully one-directional, 0.5 = random/back-and-forth).
MIN_DIRECTIONAL_CONSISTENCY=0.7
# Minimum velocity in knots to consider for pattern detection (0 = all circling).
MIN_VELOCITY_KNOTS=0

# --- LiteLLM ---
# Default model for the Front End Analyst
LITELLM_MODEL=secure-core
#secure-core
# If running in docker composition, might be http://localai:8080 or http://ollama:11434
OPEN_API_BASE=http://host.docker.internal:11434
# API key is just needed for LiteLLM to work with Offline OpenAPI models
OPEN_API_KEY=not-needed
OPEN_API_MODEL=openai/llama3
OPEN_API_LABEL=Llama3 (Local)
#public-flash
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini/gemini-2.5-flash
GEMINI_LABEL=Gemini 2.5 Flash
# deep-reasoner
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=anthropic/claude-3-5-sonnet-20240620
ANTHROPIC_LABEL=Claude 3.5 Sonnet

# --- RF Pulse ---
# ARD (Amateur Repeater Directory - open source)
RF_ARD_INTERVAL_H=24
# NOAA NWR (Weather Band Radios)
RF_NOAA_INTERVAL_H=168
# RadioReference (Public safety trunked systems)
# Requires a RadioReference premium (licensed) account + developer app key
# Get your app key at: https://www.radioreference.com/apps/api/
RADIOREF_APP_KEY=your_app_key_here
RADIOREF_USERNAME=your_rr_username_here
RADIOREF_PASSWORD=your_rr_password_here
# Lenth of time between RadioRefrence Database Pulls (in hours)
RF_RADIOREF_INTERVAL_H=168
# Comma-separated RadioReference state IDs. Leave AUTO to automatically
# select states within the RR_RADIUS_MI of your CENTER_LAT/CENTER_LON.
RADIOREF_STATE_IDS=AUTO
# UTC hour (0-23) at which the weekly RadioReference SOAP fetch is allowed to run.
# Set to -1 to disable (fetch immediately when interval elapses).
RF_RR_FETCH_HOUR=4

# --- Frontend ---
# Set to false to force MapLibre fallback even if a token is present
VITE_ENABLE_MAPBOX=true
# Mapbox: Get from https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here
# Toggle 3D terrain/elevation (may impact performance)
VITE_ENABLE_3D_TERRAIN=false
# API Base URL for the frontend application (usually proxied through Nginx)
VITE_API_URL=http://localhost

# --- CORS & Network ---
# Comma-separated list of allowed origins for the backend and radio bridge.
# When running on a server, add http://<SERVER_IP> here.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
#JS8 Websocket Host
VITE_JS8_WS_URL=http://localhost
VITE_JS8_BASE_URL=http://localhost